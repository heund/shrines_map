{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/map"
    },
    {
      "source": "/index.html",
      "destination": "/api/map"
    },
    {
      "source": "/login",
      "destination": "/api/login-page"
    },
    {
      "source": "/logout",
      "destination": "/api/logout"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
